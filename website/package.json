{
  "name": "queue",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "cleanup": "nuxt cleanup",
    "build": "npm run build:nuxt",
    "build:nuxt": "nuxt build",
    "build:dev": "npm run build:nuxt:dev",
    "build:nuxt:dev": "npx --no nuxt prepare && npx --no nuxt build --envName development",
    "dev": "nuxt dev",
    "test": "npm run test:types",
    "test:types": "vue-tsc -b --noEmit",
    "test:lint": "oxlint -c ../.oxlintrc.json",
    "generate": "nuxt generate",
    "preview": "npm run build:nuxt && nuxt preview",
    "preview:dev": "npm run build:nuxt:dev && nuxt preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@iconify-json/fluent": "1.2.52",
    "@iconify-json/heroicons": "1.2.3",
    "@iconify-json/pajamas": "1.2.15",
    "@iconify-json/uil": "1.2.3",
    "@nuxt/content": "3.15.0",
    "@nuxt/icon": "2.3.1",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/vue-table": "8.21.3",
    "@vueuse/core": "14.3.0",
    "better-sqlite3": "12.11.1",
    "d3": "7.9.0",
    "es-toolkit": "1.49.0",
    "linkifyjs": "4.3.3",
    "luxon": "3.7.2",
    "nuxt": "4.4.8",
    "nuxt-vitalizer": "2.0.0",
    "reka-ui": "2.10.1",
    "tailwindcss": "4.3.2",
    "vue": "3.5.39",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/d3": "7.4.3",
    "@types/luxon": "3.7.2",
    "@types/node": "26.1.1",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "peerDependencies": {
    "typescript": "6.0.3"
  }
}
