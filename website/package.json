{
  "name": "queue",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "cleanup": "nuxt cleanup",
    "build": "npm run build:nuxt",
    "build:nuxt": "nuxt build",
    "build:dev": "npm run build:nuxt:dev",
    "build:nuxt:dev": "npx --no nuxt prepare && npx --no nuxt build --envName development",
    "dev": "nuxt dev",
    "test": "npm run test:types",
    "test:types": "vue-tsc -b --noEmit",
    "test:lint": "oxlint",
    "generate": "nuxt generate",
    "preview": "npm run build:nuxt && nuxt preview",
    "preview:dev": "npm run build:nuxt:dev && nuxt preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@iconify-json/fluent": "1.2.46",
    "@iconify-json/pajamas": "1.2.15",
    "@nuxt/content": "3.13.0",
    "@nuxt/icon": "2.2.2",
    "@nuxtjs/color-mode": "4.0.0",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/vue-table": "8.21.3",
    "@vueuse/core": "14.3.0",
    "better-sqlite3": "12.9.0",
    "d3": "7.9.0",
    "es-toolkit": "1.46.1",
    "luxon": "3.7.2",
    "nuxt": "4.4.5",
    "nuxt-vitalizer": "2.0.0",
    "reka-ui": "2.9.7",
    "tailwindcss": "4.3.0",
    "vue": "3.5.34",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/d3": "7.4.3",
    "@types/luxon": "3.7.1",
    "@types/node": "25.7.0",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "vitest": "3.2.4",
    "vue-tsc": "3.0.5"
  },
  "peerDependencies": {
    "typescript": "5.9.2"
  }
}
