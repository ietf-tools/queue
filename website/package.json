{
  "name": "queue",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "cleanup": "nuxt cleanup",
    "build": "npm run build:nuxt",
    "build:nuxt": "nuxt build",
    "build:nuxt:dev": "npx --no nuxt prepare && npx --no nuxt build --envName development",
    "dev": "nuxt dev",
    "test": "npm run test:types",
    "test:types": "vue-tsc -b --noEmit",
    "generate": "nuxt generate",
    "preview": "npm run build:nuxt && nuxt preview",
    "preview:dev": "npm run build:nuxt:dev && nuxt preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxt/content": "3.7.1",
    "@nuxt/icon": "1.13.0",
    "@nuxtjs/color-mode": "3.4.4",
    "@tailwindcss/vite": "4.1.16",
    "@tanstack/vue-table": "8.21.3",
    "@vueuse/core": "13.1.0",
    "better-sqlite3": "12.2.0",
    "d3": "7.9.0",
    "es-toolkit": "1.44.0",
    "luxon": "3.5.0",
    "nuxt": "4.3.0",
    "nuxt-vitalizer": "2.0.0",
    "reka-ui": "2.4.1",
    "tailwindcss": "4.1.16",
    "vue": "3.5.13",
    "zod": "3.25.30"
  },
  "devDependencies": {
    "@types/d3": "7.4.3",
    "@types/luxon": "3.4.2",
    "@types/node": "25.5.2",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "vitest": "3.2.4",
    "vue-tsc": "3.0.5"
  },
  "peerDependencies": {
    "typescript": "5.9.2"
  }
}
