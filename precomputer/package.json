{
  "name": "precomputer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/test.ts",
  "scripts": {
    "job": "node src/job.ts",
    "format": "npx prettier --config ./prettier.config.cjs src --write",
    "test": "TZ=UTC npm run test:types",
    "test:types": "vue-tsc -b --noEmit",
    "test:unittests": "TZ=UTC vitest run",
    "test:unittests:watch": "TZ=UTC vitest run --watch",
    "generate:api-client": "npx --no @openapitools/openapi-generator-cli generate --generator-key purple",
    "dev-api-server": "node --experimental-transform-types ./src/utils/dev-api-server.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ietf-tools/queue.git"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.993.0",
    "@openapitools/openapi-generator-cli": "2.29.0",
    "@supercharge/promise-pool": "3.2.0",
    "es-toolkit": "1.44.0",
    "fastify": "5.7.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.0.10",
    "typescript": "5.8.3",
    "vitest": "4.0.18",
    "vue-tsc": "3.2.5"
  }
}
