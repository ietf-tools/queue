{
  "name": "precomputer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/test.ts",
  "scripts": {
    "job": "node src/job.ts",
    "format": "npx prettier --config ./prettier.config.cjs src --write",
    "test": "TZ=UTC npm run test:unittests && npm run test:types",
    "test:types": "vue-tsc -b --noEmit",
    "test:unittests": "NODE_OPTIONS=--experimental-print-required-tla TZ=UTC vitest run",
    "test:unittests:watch": "TZ=UTC vitest run --watch",
    "generate:api-client": "npx --no @openapitools/openapi-generator-cli generate --generator-key purple",
    "dev-api-server": "node --experimental-transform-types ./src/utils/dev-api-server.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ietf-tools/queue.git"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1084.0",
    "@openapitools/openapi-generator-cli": "2.39.1",
    "@supercharge/promise-pool": "3.3.0",
    "es-toolkit": "1.49.0",
    "jsdom": "29.1.1",
    "libxml2-wasm": "0.7.1",
    "luxon": "3.7.2",
    "sharp": "0.35.3",
    "sitemap": "9.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3",
    "@types/luxon": "3.7.2",
    "@types/node": "26.1.1",
    "fastify": "5.10.0",
    "typescript": "6.0.3",
    "vite-plugin-top-level-await": "1.6.0",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  }
}
